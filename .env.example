# Copie este ficheiro para ".env" e ajuste os valores antes de subir em produção.

POSTGRES_DB=lojavirtual
POSTGRES_USER=lojavirtual
POSTGRES_PASSWORD=lojavirtual_dev_pwd

JWT_SECRET=dev-only-secret-key-nao-usar-em-producao-troque-isto-1234567890

SEED_ADMIN_EMAIL=admin@lojavirtual.ao
SEED_ADMIN_PASSWORD=Trocar@123!

# URL pública da API, usada pelo browser (build-time do frontend).
NEXT_PUBLIC_API_URL=http://localhost:5050

# Origem permitida pelo CORS da API para o frontend.
FRONTEND_ORIGIN=http://localhost:3000

# Opcional: número de WhatsApp da loja (só dígitos, com código do país, ex: 244923456789).
# Deixe vazio para ocultar o botão flutuante do WhatsApp na loja.
NEXT_PUBLIC_WHATSAPP_NUMBER=
